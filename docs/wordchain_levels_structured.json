  "validationRules": {
    "operationRules": [
      {
        "name": "Swap",
        "description": "Replace exactly 1 letter. Word length stays the same.",
        "example": "CAT → RAT (C→R)",
        "appliesTo": "Always active"
      },
      {
        "name": "Add",
        "description": "Insert exactly 1 letter anywhere. Word grows by 1.",
        "example": "CAT → CART (add R)",
        "appliesTo": "Resident tier+"
      },
      {
        "name": "Remove",
        "description": "Delete exactly 1 letter anywhere. Word shrinks by 1.",
        "example": "CART → CAT (drop R)",
        "appliesTo": "Resident tier+"
      }
    ],
    "validationChecks": [
      {
        "name": "1. Empty check",
        "description": "Reject if input is blank",
        "example": "—",
        "appliesTo": "Client-side"
      },
      {
        "name": "2. Length check",
        "description": "Reject if word < 2 or > 10 letters",
        "example": "—",
        "appliesTo": "Client-side"
      },
      {
        "name": "3. Character check",
        "description": "Reject if non-alphabetical characters present",
        "example": "—",
        "appliesTo": "Client-side"
      },
      {
        "name": "4. Operation check",
        "description": "Verify differs from current word by exactly 1 valid op",
        "example": "—",
        "appliesTo": "Client-side"
      },
      {
        "name": "5. Dictionary check",
        "description": "Verify word exists in 50K-word dictionary",
        "example": "—",
        "appliesTo": "Client-side"
      },
      {
        "name": "6. Theme check",
        "description": "Verify word is in active theme list (if not Free Play)",
        "example": "—",
        "appliesTo": "Client-side"
      },
      {
        "name": "7. Loop check",
        "description": "Verify word has not appeared earlier in current chain",
        "example": "—",
        "appliesTo": "Client-side"
      }
    ],
    "themeWordLists": [
      {
        "name": "Free Play",
        "description": "All ~50,000 dictionary words. No theme restriction.",
        "example": "Any valid word",
        "appliesTo": "Tiers 1 + 4"
      },
      {
        "name": "Animals",
        "description": "~800 curated animal names (mammals, birds, reptiles, fish, insects)",
        "example": "cat, shark, egret, cobra",
        "appliesTo": "Tier 2"
      },
      {
        "name": "Food*",
        "description": "Food endpoints, free routing. Start & end must be food words.",
        "example": "tart, corn, lime, kale",
        "appliesTo": "Tier 3"
      },
      {
        "name": "Body*",
        "description": "Body endpoints, free routing. Start & end must be body words.",
        "example": "waist, hip, brain, skin",
        "appliesTo": "Tier 3"
      },
      {
        "name": "Animals*",
        "description": "Animal endpoints, free routing. Start & end must be animals.",
        "example": "hawk, lark, boar, gnat",
        "appliesTo": "Tiers 2–3"
      }
    ]
  }
